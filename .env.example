# VoltFlow Frontend — required environment variables
# Copy this file to ".env" and adjust the value for your environment.
#
# Base URL of the backend API server.
#   - NO trailing slash, NO "/api" suffix (the app appends "/api" itself).
#   - Local dev example:  http://localhost:5001
#   - Production example:  https://voltflow-server.onrender.com
#
# NOTE: Vite exposes every VITE_* variable to the browser bundle.
#       Never put secrets, passwords, DB credentials, or tokens here.
VITE_SERVER_URL=http://localhost:5001
