# VoltFlow Frontend (Vite) — copy this file to ".env" and set the values.
# Read in code with: import.meta.env.VITE_*

# Base URL of the backend server (no trailing slash, no /api suffix).
VITE_SERVER_URL=http://localhost:5001

# Weather API key (WeatherAPI.com — get a free one at https://www.weatherapi.com).
# If set, the widget uses WeatherAPI.com; if empty, it falls back to keyless Open-Meteo.
VITE_WEATHER_API_KEY=your_weatherapi_key_here

# Fallback weather API (Open-Meteo) base URL — used when no key is set above.
VITE_WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# Geocoding API (OpenStreetMap Nominatim) — turns station locations into map coordinates.
VITE_GEOCODE_API_URL=https://nominatim.openstreetmap.org/search
