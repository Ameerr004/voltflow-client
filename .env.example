# VoltFlow Frontend (Vite) — copy this file to ".env" and set the values.
# Read in code with: import.meta.env.VITE_*

# Base URL of the backend server (no trailing slash, no /api suffix).
VITE_SERVER_URL=http://localhost:5001

# Third-party weather API (Open-Meteo) base URL — used by the landing page widget.
VITE_WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
